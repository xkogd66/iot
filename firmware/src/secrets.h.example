// Copy this file to secrets.h and fill in your values.
// secrets.h is gitignored so your Wi-Fi credentials never land in the repo.
#ifndef SECRETS_H
#define SECRETS_H

// --- Wi-Fi ---
#define WIFI_SSID       "your-wifi-ssid"
#define WIFI_PASSWORD   "your-wifi-password"

// --- MQTT broker (Mosquitto on the k3s cluster, MetalLB LB IP) ---
#define MQTT_BROKER_HOST "192.168.1.211"
#define MQTT_BROKER_PORT 1883

// --- Identity: topic is sensors/<SITE>/<ROOM> ---
#define SITE            "home"
#define ROOM            "livingroom"
#define MQTT_CLIENT_ID  "az3166-home-livingroom"

#endif // SECRETS_H
