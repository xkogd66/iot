# PlatformIO
.pio/
firmware/.pio/

# macOS
.DS_Store

# Secrets (Wi-Fi credentials) — keep out of the repo. telemetry/ no longer
# uses a compile-time secrets.h (see firmware/telemetry/device_config.h); this
# only still applies to the unmaintained PlatformIO tree in firmware/src/.
firmware/src/secrets.h

# k8s secrets: only SealedSecrets (*.sealed.yaml) are safe to commit. Plaintext
# Secret sources must never land in git — seal them, then delete the source.
**/secret.yaml
**/*.secret.yaml
!**/*.sealed.yaml

# arduino-cli build output
firmware/**/build/

# scratch backups of alternate firmware versions
firmware/src/*.m2bak
firmware/src/*.wifitest
